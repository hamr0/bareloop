  "type": "module",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "license": "Apache-2.0",
  "author": "hamr0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc",
    "prepublishOnly": "npm run build:types"
  },
  "dependencies": {
    "bare-agent": "^0.29.0",
    "bareguard": "^0.12.0",
    "litectx": "^0.29.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamr0/bareloop.git"
  },
  "homepage": "https://github.com/hamr0/bareloop#readme",
  "files": [
    "src/",
    "types/",
    "NOTICE",
    "bareloop.context.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "agent",
    "workflow",
    "automation",
    "inheritance",
    "bare-suite"
