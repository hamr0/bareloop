{
  "schema": "v1",
  "loop": {
    "shape": "refine",
    "maxIterations": 4
  },
  "memory": {
    "store": "litectx",
    "recall": {
      "k": 5,
      "kinds": [
        "fact",
        "episode"
      ]
    },
    "compressLevel": "signature"
  },
  "hooks": {
    "before-attempt": [
      {
        "op": "remember",
        "kind": "fact"
      }
    ],
    "after-red": [
      {
        "op": "stash"
      }
    ],
    "on-green": [
      {
        "op": "remember",
        "kind": "fact"
      }
    ]
  },
  "gate": {
    "budgetUsd": 2,
    "writeScope": [
      "src/**"
    ]
  },
  "escalation": {
    "mode": "decision-ready"
  }
}
